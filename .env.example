# ─────────────────────────────────────────
#  Delhi 6 Backend — Environment Variables
#  Copy this file to .env and fill in real values
# ─────────────────────────────────────────

# Server
PORT=5001
NODE_ENV=production

# MongoDB (get from MongoDB Atlas dashboard)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/delhi6?retryWrites=true&w=majority

# JWT — MUST be a strong random string (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_STRING
JWT_EXPIRE=7d

# Razorpay — use PRODUCTION keys from razorpay.com dashboard (NOT rzp_test_*)
RAZORPAY_KEY_ID=rzp_live_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET

# WhatsApp Business API (Meta) — optional
WHATSAPP_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_ID=your_phone_number_id

# Frontend URL (for CORS — must be your actual production domain)
FRONTEND_URL=https://yourdomain.com

# Admin Registration Secret — MUST be a strong random string
ADMIN_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_STRING

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
